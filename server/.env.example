# SkyVault server environment variables
# Copy to .env and fill in as needed. All keys are optional — defaults live in app/config.py.

# CORS — comma-separated list of allowed frontend origins (as JSON list in env)
# CORS_ORIGINS=["http://localhost:5173"]

# Gaia ingest
# GAIA_MAG_CUTOFF=8.0
# GAIA_PARQUET_PATH=data/gaia_dr3_g8.parquet

# Sky query defaults
# DEFAULT_MAG_LIMIT=6.5
